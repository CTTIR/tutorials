# Hugo (legacy)
public/
resources/
.hugo_build.lock

# Quarto
.quarto/
_site/
/docs/.quarto/
_freeze/

# Render-time artifacts (regenerated by scripts/build_graph.py via pre-render).
# Not underscore-prefixed so Quarto ships them as resources to /artifacts/.
artifacts/
_includes/related/

# Build outputs that CI regenerates on every render — keep them out of
# git so they don't bloat history (Pagefind index is ~5 MB chunked WASM).
docs/pagefind/
docs/artifacts/

# R / RStudio
.Rproj.user/
.Rhistory
.RData

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-*

# Node (if using any build tools)
node_modules/

# Python (content generator)
__pycache__/
*.pyc
generate_tutorials.py

/.quarto/
**/*.quarto_ipynb
